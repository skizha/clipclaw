<Window x:Class="Clipclaw.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Clipclaw Settings"
        Width="480"
        Height="420"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="16">
        <TabControl Style="{DynamicResource MaterialDesignTabControl}">

            <!-- ── General tab ── -->
            <TabItem Header="General">
                <StackPanel Margin="16" VerticalAlignment="Top">

                    <TextBlock Text="History size"
                               Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="10" Maximum="500"
                                Value="{Binding Settings.MaxHistorySize}"
                                Width="300"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Style="{DynamicResource MaterialDesignSlider}" />
                        <TextBlock Text="{Binding Settings.MaxHistorySize}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>

                    <ToggleButton Margin="0,16,0,0"
                                  IsChecked="{Binding Settings.LaunchOnStartup}"
                                  Content="Launch Clipclaw with Windows"
                                  Style="{DynamicResource MaterialDesignSwitchToggleButton}" />

                    <ToggleButton Margin="0,12,0,0"
                                  IsChecked="{Binding Settings.PersistHistory}"
                                  Content="Keep history across restarts"
                                  Style="{DynamicResource MaterialDesignSwitchToggleButton}" />

                    <Button Margin="0,24,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveSettingsCommand}"
                            Content="Save"
                            Style="{DynamicResource MaterialDesignRaisedButton}" />
                </StackPanel>
            </TabItem>

            <!-- ── Shortcuts tab ── -->
            <TabItem Header="Shortcuts">
                <StackPanel Margin="16">
                    <TextBlock Text="Click a shortcut field and press the new key combination."
                               Opacity="0.7"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding Bindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ActionName}"
                                               VerticalAlignment="Center" />
                                    <TextBox  Grid.Column="1"
                                              x:Name="ShortcutField"
                                              Text="{Binding DisplayText, Mode=OneWay}"
                                              IsReadOnly="True"
                                              Cursor="Hand"
                                              Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                              PreviewKeyDown="ShortcutField_PreviewKeyDown"
                                              GotFocus="ShortcutField_GotFocus"
                                              Tag="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding ConflictMessage}"
                               Foreground="Red"
                               Margin="0,8,0,0"
                               Visibility="{Binding ConflictMessage.Length,
                                   Converter={StaticResource CountToVisibilityConverter}}" />
                </StackPanel>
            </TabItem>

            <!-- ── About tab ── -->
            <TabItem Header="About">
                <StackPanel Margin="24" VerticalAlignment="Top">
                    <TextBlock Text="Clipclaw"
                               Style="{DynamicResource MaterialDesignHeadline5TextBlock}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Version 1.0.0"
                               Opacity="0.7"
                               Margin="0,0,0,16" />
                    <TextBlock Text="A keyboard-first Windows clipboard manager."
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0">
                        <Hyperlink NavigateUri="https://github.com/skizha/clipclaw"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            github.com/skizha/clipclaw
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
