<Window x:Class="Clipclaw.Views.ClipboardPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Clipclaw"
        Width="360"
        MaxHeight="560"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Row height constant so keyboard page-jump can use it -->
        <sys:Double x:Key="RowHeight" xmlns:sys="clr-namespace:System;assembly=System.Runtime">44</sys:Double>

        <!-- SectionHeader style is replaced by inline accent-bar headers below -->

        <!--
            ClipRow — base style for all list items.
            Alternating background is handled by the DataTrigger on AlternationIndex
            so the same style works across all three ListBoxes regardless of their
            AlternationCount value.
        -->
        <Style x:Key="ClipRow" TargetType="ListBoxItem">
            <Setter Property="Padding"                    Value="16,0" />
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="Foreground"                 Value="{DynamicResource ClipRowForeground}" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
            <Style.Triggers>
                <!-- Alternating row: odd index gets a subtle shaded background -->
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <Binding Path="(ItemsControl.AlternationIndex)"
                                 RelativeSource="{RelativeSource Self}"
                                 Converter="{StaticResource IndexToOddConverter}" />
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource ClipRowAlternateBackground}" />
                </DataTrigger>
                <!-- Hover overrides alternating background -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ClipRowHoverBackground}" />
                </Trigger>
                <!-- Selection overrides hover and alternating background -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ClipRowSelectedBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource ClipRowSelectedForeground}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Thin separator between sections -->
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height"     Value="1" />
            <Setter Property="Background" Value="{DynamicResource ClipDividerBrush}" />
            <Setter Property="Margin"     Value="16,4,16,0" />
        </Style>

        <QuinticEase x:Key="OpenEase" EasingMode="EaseOut" />
    </Window.Resources>

    <!-- Open animation: fade in + 8px upward slide over 150ms -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.15"
                                     EasingFunction="{StaticResource OpenEase}" />
                    <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="8" To="0"
                                     Duration="0:0:0.15"
                                     EasingFunction="{StaticResource OpenEase}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Drop shadow + rounded card -->
    <Border x:Name="RootCard"
            CornerRadius="10"
            Background="{DynamicResource ClipPanelBackground}"
            Margin="10"
            Opacity="0"
            TextOptions.TextRenderingMode="Auto"
            TextOptions.TextFormattingMode="Display">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="8" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.7" Color="#000000" />
        </Border.Effect>

        <!-- Subtle inner border for definition -->
        <Border CornerRadius="10"
                BorderBrush="{DynamicResource ClipPanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Search -->
                    <RowDefinition Height="*" />     <!-- Scrollable list -->
                </Grid.RowDefinitions>

                <!-- Search field + Add button -->
                <Grid Grid.Row="0" Margin="12,12,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Search box -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource ClipSearchBackground}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource ClipSearchBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="⌕"
                                       FontSize="16"
                                       Foreground="{DynamicResource ClipMutedForeground}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,4,0" />
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ClipRowForeground}"
                                     CaretBrush="#E8A030"
                                     BorderThickness="0"
                                     Padding="4,10"
                                     FontSize="13"
                                     VerticalAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="SearchBox_PreviewKeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="0"
                                                                  VerticalAlignment="Center" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Placeholder text (overlays the search box) -->
                    <TextBlock Grid.Column="0"
                               IsHitTestVisible="False"
                               Text="Search clips…"
                               Foreground="{DynamicResource ClipPlaceholderForeground}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="38,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Add button (Ctrl+N) -->
                    <Button Grid.Column="1"
                            Width="34" Height="34"
                            Margin="6,0,0,0"
                            ToolTip="Add clip  (Ctrl+N)"
                            Cursor="Hand"
                            Click="AddButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg"
                                        Background="{DynamicResource ClipSearchBackground}"
                                        BorderBrush="{DynamicResource ClipSearchBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock Text="+"
                                               FontSize="18"
                                               FontWeight="Light"
                                               Foreground="#E8A030"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-1,0,0" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource ClipRowHoverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.7" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Divider under search -->
                <Border Grid.Row="0"
                        Height="1"
                        Background="{DynamicResource ClipPanelInnerBorderBrush}"
                        Margin="0,56,0,0"
                        VerticalAlignment="Bottom" />

                <!-- Scrollable clip list -->
                <ScrollViewer Grid.Row="1"
                              x:Name="ListScrollViewer"
                              Margin="0,4,0,4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="4" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ScrollViewer.Resources>

                    <StackPanel>

                        <!-- ── Column headers ── -->
                        <Grid Margin="16,16,16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="88" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="CLIP"
                                       Foreground="{DynamicResource ClipMutedForeground}"
                                       FontSize="10" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="USES"
                                       Foreground="{DynamicResource ClipMutedForeground}"
                                       FontSize="10" FontWeight="SemiBold"
                                       TextAlignment="Right" />
                            <TextBlock Grid.Column="2"
                                       Text="SHORTCUT"
                                       Foreground="{DynamicResource ClipMutedForeground}"
                                       FontSize="10" FontWeight="SemiBold"
                                       TextAlignment="Right" />
                        </Grid>
                        <Border Height="1"
                                Background="{DynamicResource ClipDividerBrush}"
                                Margin="16,0,16,0" />

                        <!-- ── Pinned section ── -->
                        <StackPanel Visibility="{Binding PinnedItems.Count,
                                        Converter={StaticResource CountToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="16,14,16,4">
                                <Border Width="3" CornerRadius="1.5" Background="#E8A030"
                                        VerticalAlignment="Stretch" Margin="0,0,8,0" />
                                <TextBlock Text="PINNED"
                                           Foreground="#E8A030"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ListBox x:Name="PinnedList"
                                     ItemsSource="{Binding PinnedItems}"
                                     SelectedItem="{Binding SelectedItem, Mode=OneWay}"
                                     ItemContainerStyle="{StaticResource ClipRow}"
                                     AlternationCount="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="AnyList_SelectionChanged"
                                     MouseRightButtonUp="AnyList_MouseRightButtonUp">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="44">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="88" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Primary label -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding DisplayLabel}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,10,4,0"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding Foreground,
                                                           RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />

                                            <!-- Secondary text preview (only when ShortName is set) -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="{Binding DisplayText}"
                                                       FontSize="10"
                                                       Margin="0,1,4,8"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource ClipMutedForeground}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasShortName}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Uses count -->
                                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PasteCount,
                                                               Converter={StaticResource CopyCountDisplayConverter}}"
                                                           Foreground="{DynamicResource ClipBadgeForeground}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="★"
                                                           Foreground="#E8A030"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,0,0" />
                                            </StackPanel>

                                            <!-- Shortcut: shows slot-assigned key if set -->
                                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                       Text="{Binding ShortcutLabel}"
                                                       Foreground="{DynamicResource ClipBadgeForeground}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Style="{StaticResource SectionDivider}" />
                        </StackPanel>

                        <!-- ── Frequently Used section ── -->
                        <StackPanel Visibility="{Binding FrequentItems.Count,
                                        Converter={StaticResource CountToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="16,14,16,4">
                                <Border Width="3" CornerRadius="1.5" Background="#7B8BE8"
                                        VerticalAlignment="Stretch" Margin="0,0,8,0" />
                                <TextBlock Text="FREQUENT"
                                           Foreground="#7B8BE8"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ListBox x:Name="FrequentList"
                                     ItemsSource="{Binding FrequentItems}"
                                     SelectedItem="{Binding SelectedItem, Mode=OneWay}"
                                     ItemContainerStyle="{StaticResource ClipRow}"
                                     AlternationCount="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="AnyList_SelectionChanged"
                                     MouseRightButtonUp="AnyList_MouseRightButtonUp">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="44">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="88" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Primary label -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding DisplayLabel}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,10,4,0"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding Foreground,
                                                           RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />

                                            <!-- Secondary text preview (when ShortName set) -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="{Binding DisplayText}"
                                                       FontSize="10"
                                                       Margin="0,1,4,8"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource ClipMutedForeground}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasShortName}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Uses count -->
                                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                       Text="{Binding PasteCount,
                                                           Converter={StaticResource CopyCountDisplayConverter}}"
                                                       Foreground="{DynamicResource ClipBadgeForeground}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />

                                            <!-- Shortcut: shows slot-assigned key if set -->
                                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                       Text="{Binding ShortcutLabel}"
                                                       Foreground="{DynamicResource ClipBadgeForeground}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Style="{StaticResource SectionDivider}" />
                        </StackPanel>

                        <!-- ── Recent section ── -->
                        <StackPanel Orientation="Horizontal" Margin="16,14,16,4">
                            <Border Width="3" CornerRadius="1.5" Background="#5ABFA8"
                                    VerticalAlignment="Stretch" Margin="0,0,8,0" />
                            <TextBlock Text="RECENT"
                                       Foreground="#5ABFA8"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <ListBox x:Name="RecentList"
                                 ItemsSource="{Binding RecentItems}"
                                 SelectedItem="{Binding SelectedItem, Mode=OneWay}"
                                 ItemContainerStyle="{StaticResource ClipRow}"
                                 AlternationCount="100"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionChanged="AnyList_SelectionChanged"
                                 MouseRightButtonUp="AnyList_MouseRightButtonUp">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="88" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Primary label -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding DisplayLabel}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,10,4,0"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding Foreground,
                                                       RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />

                                        <!-- Secondary text preview (when ShortName set) -->
                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{Binding DisplayText}"
                                                   FontSize="10"
                                                   Margin="0,1,4,8"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource ClipMutedForeground}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasShortName}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Uses count -->
                                        <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                   Text="{Binding PasteCount,
                                                       Converter={StaticResource CopyCountDisplayConverter}}"
                                                   Foreground="{DynamicResource ClipBadgeForeground}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />

                                        <!-- Shortcut column: explicit slot takes priority;
                                             position-based (Ctrl+Shift+1–5) shows as fallback -->
                                        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="2">
                                            <!-- Slot-assigned shortcut (shown when slot is set) -->
                                            <TextBlock Text="{Binding ShortcutLabel}"
                                                       Visibility="{Binding HasShortcutLabel,
                                                           Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Foreground="{DynamicResource ClipBadgeForeground}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                            <!-- Position-based fallback (collapsed when slot is assigned) -->
                                            <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex),
                                                           RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                                           Converter={StaticResource IndexToShortcutConverter}}"
                                                       Foreground="{DynamicResource ClipBadgeForeground}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasShortcutLabel}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <TextBlock Margin="16,12"
                                   Text="No clipboard items yet."
                                   Foreground="{DynamicResource ClipPlaceholderForeground}"
                                   FontSize="13"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding PinnedItems.Count}"   Value="0" />
                                                <Condition Binding="{Binding FrequentItems.Count}" Value="0" />
                                                <Condition Binding="{Binding RecentItems.Count}"   Value="0" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</Window>
