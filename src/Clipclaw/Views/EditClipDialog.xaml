<Window x:Class="Clipclaw.Views.EditClipDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Clip"
        Width="380"
        SizeToContent="Height"
        MaxHeight="520"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ClipPanelBackground}"
        Foreground="{DynamicResource ClipRowForeground}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ClipMutedForeground}" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,4" />
        </Style>

        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource ClipSearchBackground}" />
            <Setter Property="Foreground"               Value="{DynamicResource ClipRowForeground}" />
            <Setter Property="CaretBrush"               Value="#E8A030" />
            <Setter Property="BorderBrush"              Value="{DynamicResource ClipSearchBorderBrush}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="Padding"                  Value="10,8" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Top" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8A030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlotCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource ClipSearchBackground}" />
            <Setter Property="Foreground"      Value="{DynamicResource ClipRowForeground}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource ClipSearchBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="10,8" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Height"          Value="36" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="Medium" />
            <Setter Property="Padding"         Value="18,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,20,24,24">

        <!-- Short Name field -->
        <TextBlock Text="SHORT NAME (optional)"
                   Style="{StaticResource FieldLabel}" />
        <TextBox x:Name="ShortNameBox"
                 MaxLength="60"
                 Style="{StaticResource EditBox}"
                 Margin="0,0,0,16"
                 PreviewKeyDown="ShortNameBox_PreviewKeyDown" />

        <!-- Clip Text field -->
        <TextBlock Text="CLIP TEXT"
                   Style="{StaticResource FieldLabel}" />
        <TextBox x:Name="TextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinLines="4"
                 MaxLines="10"
                 VerticalScrollBarVisibility="Auto"
                 Style="{StaticResource EditBox}"
                 Margin="0,0,0,4"
                 PreviewKeyDown="TextBox_PreviewKeyDown" />

        <TextBlock Text="Ctrl+Enter to save when editing text"
                   Foreground="{DynamicResource ClipPlaceholderForeground}"
                   FontSize="11"
                   Margin="0,0,0,16" />

        <!-- Shortcut slot picker -->
        <TextBlock Text="SHORTCUT KEY (optional)"
                   Style="{StaticResource FieldLabel}" />
        <!-- Items are populated in code-behind (BuildSlotItems) so occupied slots
             can be annotated with the name of the item that currently holds them. -->
        <ComboBox x:Name="SlotComboBox"
                  Style="{StaticResource SlotCombo}"
                  Margin="0,0,0,4" />
        <TextBlock Text="Assigns a global Ctrl+Shift+N hotkey directly to this item"
                   Foreground="{DynamicResource ClipPlaceholderForeground}"
                   FontSize="11"
                   Margin="0,0,0,20" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Background="{DynamicResource ClipSearchBackground}"
                    Foreground="{DynamicResource ClipMutedForeground}"
                    Margin="0,0,10,0"
                    Style="{StaticResource ActionButton}"
                    Click="CancelButton_Click" />
            <Button x:Name="SaveButton"
                    Content="Save"
                    Background="#E8A030"
                    Foreground="#0F0F18"
                    Style="{StaticResource ActionButton}"
                    Click="SaveButton_Click" />
        </StackPanel>

    </StackPanel>
</Window>
